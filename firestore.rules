rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------
    // Global Safety Net
    // ---------------------------------------------------------
    match /{document=**} {
      allow read, write: if false;
    }

    // ---------------------------------------------------------
    // Primitives & Helpers
    // ---------------------------------------------------------
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { 
      return isSignedIn() && (
        request.auth.token.email == 'roshan92793@gmail.com' ||
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin'
      ); 
    }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // ---------------------------------------------------------
    // Users Collection
    // ---------------------------------------------------------
    match /users/{userId} {
      allow get: if isOwner(userId) || isAdmin();
      allow list: if isAdmin();
      
      function isValidUser(data) {
        return data.uid == request.auth.uid
          && data.email is string && data.email.size() < 100
          && data.role in ['student', 'admin']
          && data.xp is int && data.level is int
          && data.streak is int;
      }

      allow create: if isOwner(userId) && isValidUser(incoming()) && incoming().role == 'student';
      allow update: if (isOwner(userId) || isAdmin()) && (
        // Allow stats update
        incoming().diff(existing()).affectedKeys().hasOnly(['xp', 'level', 'streak', 'lastActive', 'badges', 'displayName', 'avatar']) ||
        isAdmin() // Admins can change roles
      );
    }

    // ---------------------------------------------------------
    // Courses Collection
    // ---------------------------------------------------------
    match /courses/{courseId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // ---------------------------------------------------------
    // Enrollments Collection
    // ---------------------------------------------------------
    match /enrollments/{enrollmentId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid
        && incoming().progress == 0
        && incoming().status == 'active'
        && exists(/databases/$(database)/documents/courses/$(incoming().courseId));
        
      allow update: if isSignedIn() 
        && (existing().userId == request.auth.uid || isAdmin())
        && incoming().diff(existing()).affectedKeys().hasOnly(['progress', 'status', 'completedAt']);
    }

    // ---------------------------------------------------------
    // Certificates Collection
    // ---------------------------------------------------------
    match /certificates/{certId} {
      allow list: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      allow get: if isSignedIn() && (resource.data.userId == request.auth.uid || isAdmin());
      
      allow create: if isSignedIn() 
        && incoming().userId == request.auth.uid
        && incoming().verified == false;
        
      allow update: if isAdmin() 
        && incoming().diff(existing()).affectedKeys().hasOnly(['verified']);
      
      allow delete: if isAdmin();
    }
  }
}
